# ResearchPilot Configuration

# AIMALabs API Key (Required) - Get yours at https://aimlapi.com
AIMLABS_API_KEY=AIMALabs_API_KEY

# AIMALabs API Base URL (Optional, defaults to https://api.aimlapi.com/v1)
AIMLABS_BASE_URL=https://api.aimlapi.com/v1

# Model Selection (Optional, defaults shown)
# Cheap options: gpt-4o-mini, gemini-2.0-flash-lite, llama-3.1-8b-instant
AIMLABS_CHAT_MODEL=gpt-4o-mini

# Embedding model (Optional, defaults to text-embedding-3-small)
# Options: text-embedding-3-small (1536 dim), text-embedding-3-large (3072 dim)
AIMLABS_EMBEDDING_MODEL=text-embedding-3-small

# Local ChromaDB Path (Optional, defaults to chroma_db/)
CHROMA_DB_PATH=chroma_db/

# Orchestrator parameters
MAX_CRITIQUE_LOOPS=2
LOG_LEVEL=INFO

# Academic API limits
SEMANTIC_SCHOLAR_LIMIT=5
ARXIV_LIMIT=5
